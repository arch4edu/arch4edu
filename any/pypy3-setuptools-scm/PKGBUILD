# Maintainer: Carlos Aznarán <caznaranl@uni.pe>
_base=setuptools-scm
pkgname=pypy3-${_base}
pkgdesc="the blessed package to manage your versions by scm tags"
pkgver=10.2.0
pkgrel=1
arch=(any)
url="https://github.com/pypa/${_base}"
license=(MIT)
depends=(pypy3-packaging pypy3-setuptools)
makedepends=(pypy3-build pypy3-installer)
source=(${_base}-${pkgver}.tar.gz::${url}/archive/${_base}-v${pkgver}.tar.gz)
sha512sums=('108af06192e718819c006c6a667cb67684586e7818c5311823c2bf2e79c44cbbc53ccdf3c89f5b58342a8a47cdcc34f73490f935a8b4cfecab5d2b49a2e04a43')

build() {
  cd ${_base}-${_base}-v${pkgver}/${_base}
  export SETUPTOOLS_SCM_PRETEND_VERSION=${pkgver}
  mkdir -p "$srcdir/_bootstrap"
  cp -r ../vcs-versioning/src/vcs_versioning "$srcdir/_bootstrap/"
  export PYTHONPATH="$srcdir/_bootstrap:${PYTHONPATH:-}"
  pypy3 -m build --wheel --skip-dependency-check --no-isolation
}

package() {
  cd ${_base}-${_base}-v${pkgver}/${_base}
  PYTHONPYCACHEPREFIX="${PWD}/.cache/cpython/" pypy3 -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm 644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}"
}
