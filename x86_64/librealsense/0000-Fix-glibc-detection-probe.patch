From 5e4e754bd94fd27104261fdc5260c41e1607f556 Mon Sep 17 00:00:00 2001
From: Avia Avraham <145359432+AviaAv@users.noreply.github.com>
Date: Thu, 28 May 2026 14:52:36 +0300
Subject: [PATCH] rosbag2: fix glibc detection probe (gcc>=14)

---
 .../realsense-file/rosbag2/config.cmake       | 15 ++++++--
 .../cmake/check_c_compiler_uses_glibc.cmake   | 36 -------------------
 2 files changed, 13 insertions(+), 38 deletions(-)
 delete mode 100644 third-party/realsense-file/rosbag2/rcutils/cmake/check_c_compiler_uses_glibc.cmake

diff --git a/third-party/realsense-file/rosbag2/config.cmake b/third-party/realsense-file/rosbag2/config.cmake
index 8931836f5..201d3ec9d 100644
--- a/third-party/realsense-file/rosbag2/config.cmake
+++ b/third-party/realsense-file/rosbag2/config.cmake
@@ -72,8 +72,19 @@ set(ROSBAG2_COMPILE_FLAGS "${ROSBAG2_COMPILE_FLAGS};RCPPUTILS_BUILDING_LIBRARY")
 
 # -- rcutils --
 if(UNIX AND NOT APPLE)
-    include(${CMAKE_CURRENT_LIST_DIR}/rcutils/cmake/check_c_compiler_uses_glibc.cmake)
-    check_c_compiler_uses_glibc(USES_GLIBC)
+    # Detect glibc to enable _GNU_SOURCE. rcutils' upstream probe passes &buffer
+    # (void*(*)[1]) to backtrace() which expects void**; gcc >= 14 errors on it,
+    # wrongly failing the check on glibc. Probe inline with the correct argument.
+    include(CheckCSourceCompiles)
+    check_c_source_compiles("
+        #include <execinfo.h>
+        int main() {
+          void * buffer[1];
+          int size = sizeof(buffer) / sizeof(void *);
+          backtrace(buffer, size);
+          return 0;
+        }
+    " USES_GLIBC)
     if(USES_GLIBC)
         set(ROSBAG2_COMPILE_FLAGS "${ROSBAG2_COMPILE_FLAGS};_GNU_SOURCE")
     endif()
diff --git a/third-party/realsense-file/rosbag2/rcutils/cmake/check_c_compiler_uses_glibc.cmake b/third-party/realsense-file/rosbag2/rcutils/cmake/check_c_compiler_uses_glibc.cmake
deleted file mode 100644
index 9958f9e74..000000000
--- a/third-party/realsense-file/rosbag2/rcutils/cmake/check_c_compiler_uses_glibc.cmake
+++ /dev/null
@@ -1,36 +0,0 @@
