pkgname=libdart
pkgver=6.15.0
pkgrel=2
pkgdesc="Dynamic Animation and Robotics Toolkit"
arch=('i686' 'x86_64')
url="https://dartsim.github.io"
license=('BSD')
depends=('assimp' 'boost' 'eigen' 'fcl' 'libccd' 'bullet' 'coin-or-ipopt'
         'nlopt' 'octomap' 'ode' 'openscenegraph' 'tinyxml2' 'urdfdom'
         'glu' 'freeglut' 'libxi' 'libxmu' 'pagmo' 'fmt' 'spdlog')
optdepends=('pagmo: pagmo optimizer support')
makedepends=('cmake')
provides=('dartsim')
_pkgname=dart
source=(
    "${pkgname}-${pkgver}.tar.gz::https://github.com/dartsim/${_pkgname}/archive/v${pkgver}.tar.gz"
    "arch-fixes.patch"
)
sha256sums=(
    'bbf954e283f464f6d0a8a5ab43ce92fd49ced357ccdd986c7cb4c29152df8692'
    '4ee0b09c6cb1deff5c09a55114bd15ae13fe81128885e1ea1500fe81af87a360'
)

prepare() {
    cd "${srcdir}/${_pkgname}-${pkgver}"
    patch -p1 -i "${srcdir}/arch-fixes.patch"
}

build() {
    mkdir -p "${srcdir}/${_pkgname}-${pkgver}/build"
    cd "${srcdir}/${_pkgname}-${pkgver}/build"

    # -include cassert: GCC 16's libstdc++ no longer transitively pulls in
    # <cassert>, but many DART sources call assert() without including it.
    export CXXFLAGS="$CFLAGS -include cassert"
    cmake .. \
        -DCMAKE_INSTALL_PREFIX="/usr" \
        -DCMAKE_INSTALL_LIBDIR="lib" \
        -DDART_TREAT_WARNINGS_AS_ERRORS="off"

    make
}

package() {
    cd "${srcdir}/${_pkgname}-${pkgver}/build"

    make DESTDIR="${pkgdir}/" install
}
makedepends+=("fmt" "git")
