_pkgname=kit
_pkgver=0.0.21
pkgname=r-${_pkgname,,}
pkgver=${_pkgver//-/.}
pkgrel=1
pkgdesc="Data Manipulation Functions Implemented in C"
arch=(x86_64)
url="https://cran.r-project.org/package=$_pkgname"
license=('GPL-3.0-only')
depends=(
  r
)
source=("https://cran.r-project.org/src/contrib/${_pkgname}_${_pkgver}.tar.gz")
md5sums=('43fa595b74137967ff57fb8664e030c0')
b2sums=('b235a2dab1fad047263b439d351eb08c4dce2ea256b2a189de6b1e6ab929b67bd8b3fa35d6d221bc7cc76b4f8ab645c676d8e39e172cde2813bfa8dd7c708fe2')

build() {
  mkdir build
  R CMD INSTALL -l build "$_pkgname"
}

package() {
  install -d "$pkgdir/usr/lib/R/library"
  cp -a --no-preserve=ownership "build/$_pkgname" "$pkgdir/usr/lib/R/library"
}
