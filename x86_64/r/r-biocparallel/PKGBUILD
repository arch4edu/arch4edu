_bcname=BiocParallel
_bcver=1.46.0
pkgname=r-${_bcname,,}
pkgdesc="Bioconductor facilities for parallel evaluation"
url="https://bioconductor.org/packages/release/bioc/html/${_bcname}.html"
pkgver=${_bcver//[:-]/.}
pkgrel=1

arch=("i686" "x86_64")
license=("GPL2" "GPL3")

depends=(
    "r>=3.5.0"
    "r-bh"
    "r-codetools"
    "r-cpp11"
    "r-futile.logger"
    "r-snow"
)
optdepends=(
    "r-batchtools"
    "r-bbmisc"
    "r-biocgenerics"
    "r-biocstyle"
    "r-data.table"
    "r-doparallel"
    "r-foreach"
    "r-genomicalignments"
    "r-genomicranges"
    "r-knitr"
    "r-rnaseqdata.hnrnpc.bam.chr14"
    "r-rsamtools"
    "r-runit"
    "r-shortread"
    "r-txdb.hsapiens.ucsc.hg19.knowngene"
    "r-variantannotation"
)

source=("https://bioconductor.org/packages/release/bioc/src/contrib/${_bcname}_${_bcver}.tar.gz")
b2sums=('06df1a3c79ad2e43ad769e8f3a9680770526658b04144d5f133a1ffc785b916c422d12dc5793b9662c117fc01c5a6d9bd7eec81448d667af0b58f111b0c47f6c')

build() {
  tar xzf ${_bcname}_${_bcver}.tar.gz
  sed -i "s#boost_patch_1_87/interprocess/managed_shared_memory.hpp#boost/interprocess/managed_shared_memory.hpp#" ${_bcname}/src/ipcmutex.cpp
  tar czf ${_bcname}_${_bcver}.tar.gz ${_bcname}
  R CMD INSTALL ${_bcname}_${_bcver}.tar.gz -l "${srcdir}"
}

package() {
  install -dm0755 "${pkgdir}/usr/lib/R/library"
  cp -a --no-preserve=ownership "${_bcname}" "${pkgdir}/usr/lib/R/library"

  if [[ -f "${_bcname}/LICENSE" ]]; then
    install -Dm0644 "${_bcname}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  fi

}
